# CoachAI environment variables
# Copy to .env and edit as needed.

# ---- QVAC (on-device AI) ----
# Enabled by default. The backend spawns a Bare worker that loads Llama 3.2 1B.
QVAC_ENABLED=true
QVAC_SPAWN=true
# Override model path (defaults to models/Llama-3.2-1B-Instruct-Q4_K_M.gguf)
# QVAC_MODEL_PATH=/absolute/path/to/model.gguf
# Inference params
QVAC_CTX=4096
QVAC_TEMP=0.6
QVAC_MAX_TOKENS=384

# ---- WDK (self-custody wallet) ----
# TRON Nile testnet — free, Tether-aligned (USDT native chain)
WALLET_CHAIN=tron
WALLET_PROVIDER=https://nile.trongrid.io
# Optional: pre-set wallet seed (otherwise generated on first run & persisted to .coachai/seed.txt)
# WALLET_SEED=word word word ...
# Tip cap in sun (1 TRX = 1_000_000 sun)
TIP_CAP_SUN=100000000

# ---- Football data (optional, live fixtures) ----
# Get a free token at https://www.football-data.org/
# FOOTBALL_DATA_TOKEN=your_token_here

# ---- Backend ----
PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=*

# ---- Frontend (Vite) ----
# Set to backend URL for remote deploys. Empty = same-origin (dev proxy).
# VITE_API_URL=http://localhost:8000
